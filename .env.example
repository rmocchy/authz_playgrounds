# Copy to .env for local docker compose (never commit .env).
# Placeholders only — change before any real use.
#
# Hostnames db / auth / memo are Docker Compose network DNS names (not localhost).
# Container-internal ports are fixed: auth 3001, memo 3002, web 5173, postgres 5432.
# AUTH_PORT / MEMO_PORT / WEB_PORT / POSTGRES_PORT only change host publish mappings.

# --- Postgres (compose service: db) ---
POSTGRES_USER=playground
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
# Host publish only (container always listens on 5432)
POSTGRES_PORT=5432

# --- Auth (app authz platform — NOT an IdP) ---
# Host publish only (container always listens on 3001)
AUTH_PORT=3001
# Password in URL must match POSTGRES_PASSWORD above.
# sslmode=disable: local compose Postgres has no TLS (required by dbmate).
AUTH_DATABASE_URL=postgres://playground:changeme@db:5432/auth?sslmode=disable
# Session lifetime (seconds); default 7 days
SESSION_TTL_SECONDS=604800
# Set true only when Auth is served over HTTPS
COOKIE_SECURE=false

# --- Memo API ---
# Host publish only (container always listens on 3002)
MEMO_PORT=3002
# Password in URL must match POSTGRES_PASSWORD above.
MEMO_DATABASE_URL=postgres://playground:changeme@db:5432/memo?sslmode=disable

# --- Web FE ---
# Host publish only (container always listens on 5173)
WEB_PORT=5173

# --- Shared session cookie (Auth issues; browser sends to proxied APIs) ---
SESSION_COOKIE_NAME=playground_session

# Optional: seed user on Auth boot (local learning only).
# Uncomment to get a ready-made login without using Register in the UI.
# SEED_LOGIN_ID=demo
# SEED_PASSWORD=changeme
