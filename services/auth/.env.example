# Auth service env (copy for local `deno task start` outside compose).
# Never commit real secrets. Compose injects these from repo-root .env.

# Listen port (container-fixed 3001 in compose)
PORT=3001

# Postgres auth DB (host path when running Deno on host)
DATABASE_URL=postgres://playground:changeme@localhost:5432/auth

# Session cookie
SESSION_COOKIE_NAME=playground_session
# Session lifetime in seconds (default 7 days)
SESSION_TTL_SECONDS=604800

# Cookie Secure flag (false for local HTTP; true behind HTTPS)
COOKIE_SECURE=false

# Optional seed user on startup (local learning only)
# SEED_LOGIN_ID=demo
# SEED_PASSWORD=changeme
