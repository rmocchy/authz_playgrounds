{
  "name": "@authz/auth",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "start": "deno run -A src/main.ts",
    "dev": "deno run -A --watch src/main.ts",
    "test": "deno test -A tests/",
    "check": "deno check src/main.ts",
    "lint:architecture": "deno run -A --config ../../tools/architecture-lint/deno.json ../../tools/architecture-lint/run.ts --service auth"
  },
  "imports": {
    "postgres": "npm:postgres@3.4.5",
    "bcryptjs": "npm:bcryptjs@2.4.3",
    "@std/assert": "jsr:@std/assert@1",
    "@std/uuid": "jsr:@std/uuid@1"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"]
  }
}
