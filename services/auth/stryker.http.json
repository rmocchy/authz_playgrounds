{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "deno test -A --quiet tests/auth_http_test.ts"
  },
  "mutate": [
    "src/routes/auth.ts",
    "src/routes/sessions.ts"
  ],
  "coverageAnalysis": "off",
  "timeoutMS": 120000,
  "timeoutFactor": 2,
  "concurrency": 2,
  "packageManager": "npm",
  "symlinkNodeModules": false,
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "thresholds": {
    "high": 80,
    "low": 50,
    "break": 50
  },
  "reporters": [
    "clear-text",
    "progress",
    "html",
    "json"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/http/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/http/mutation.json"
  },
  "ignorePatterns": [
    "node_modules",
    ".git",
    "reports",
    ".stryker-tmp",
    "**/deno.lock"
  ],
  "cleanTempDir": true,
  "allowEmpty": false,
  "disableTypeChecks": true
}
