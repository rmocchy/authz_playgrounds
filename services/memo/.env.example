# Memo service env (copy for local `deno task start` outside compose).
# Never commit real secrets. Compose injects these from repo-root .env.

# Listen port (container-fixed 3002 in compose)
PORT=3002

# Postgres memo DB (host path when running Deno on host)
DATABASE_URL=postgres://playground:changeme@localhost:5432/memo?sslmode=disable

# Auth service base URL for GET /v1/sessions/me (no trailing slash)
# Compose network: http://auth:3001
# Host-local: http://localhost:3001
AUTH_BASE_URL=http://localhost:3001

# Must match Auth cookie name
SESSION_COOKIE_NAME=playground_session
