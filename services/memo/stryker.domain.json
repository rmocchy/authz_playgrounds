{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "deno test -A --quiet tests/authorize_test.ts"
  },
  "mutate": [
    "src/domain/authorize.ts"
  ],
  "coverageAnalysis": "off",
  "timeoutMS": 30000,
  "timeoutFactor": 2,
  "concurrency": 4,
  "packageManager": "npm",
  "symlinkNodeModules": false,
  "thresholds": {
    "high": 80,
    "low": 50,
    "break": 50
  },
  "reporters": [
    "clear-text",
    "progress",
    "html",
    "json"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/domain/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/domain/mutation.json"
  },
  "ignorePatterns": [
    "node_modules",
    ".git",
    "reports",
    ".stryker-tmp",
    "**/deno.lock"
  ],
  "cleanTempDir": true,
  "allowEmpty": false,
  "disableTypeChecks": true
}
